prefix=/home/thomas/event_repo/external/libcaer-prebuilt
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: libcaer
Description: Minimal C library to access, configure and get data from neuromorphic sensors and processors.
Version: 3.3.17
Requires.private: libusb-1.0 >= 1.0.17
Libs: -L${libdir} -lcaer
Libs.private: -lm 
Cflags: -I${includedir}
